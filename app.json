    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "description": "Sistem Jadwal Kuliah — tugas praktikum Pemrograman Mobile (map, FlatList, SectionList) dengan data statis.",
